{
  "name": "@nucleusenterprise/mcp-database-server",
  "version": "1.0.4",
  "description": "MCP server for querying SQL databases (PostgreSQL, MySQL, ClickHouse) with security guardrails",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mcp-database-server": "./dist/index.js",
    "db-mcp-server": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/bundle.cjs --external:pg-native --banner:js='#!/usr/bin/env node' && esbuild src/cli.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/cli-bundle.cjs --external:pg-native --banner:js='#!/usr/bin/env node'",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.1",
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.19.0",
    "node-sql-parser": "^5.3.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "database",
    "postgresql",
    "mysql",
    "clickhouse",
    "sql",
    "query",
    "masking",
    "row-filter",
    "security"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nucleusenterpriseai/database-mcp-server.git"
  },
  "homepage": "https://github.com/nucleusenterpriseai/database-mcp-server#readme"
}
