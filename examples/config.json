{
  "server": {
    "port": 8443,
    "api_key": "${MCP_API_KEY}"
  },
  "database": {
    "type": "postgres",
    "host": "db.example.com",
    "port": 5432,
    "username": "readonly_user",
    "password": "${DB_PASSWORD}",
    "database": "myapp",
    "ssl_mode": "require"
  },
  "security": {
    "allowed_tables": [],
    "masking_rules": [
      {
        "table": "users",
        "column": "email",
        "type": "email"
      },
      {
        "table": "users",
        "column": "phone",
        "type": "phone_last4"
      },
      {
        "table": "users",
        "column": "ssn",
        "type": "redact"
      }
    ],
    "row_filters": [
      {
        "table": "orders",
        "condition": "status = 'active'"
      }
    ]
  }
}
